<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F2F4F8"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Оплата"
        android:textSize="16sp"
        android:textColor="#7A8C9E" />

    <TextView
        android:id="@+id/qrAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="₽ 0"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#0B1E33"
        android:layout_marginBottom="20dp" />

    <ImageView
        android:id="@+id/qrImage"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Наведите камеру для оплаты"
        android:textSize="14sp"
        android:textColor="#7A8C9E"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnPaySmile"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="😊  Оплата улыбкой"
        android:textSize="17sp"
        android:textStyle="bold"
        android:background="#0B1E33"
        android:textColor="#FFFFFF"
        android:stateListAnimator="@null" />

</LinearLayout>
